# ─────────────────────────────────────────────
# DATABASE (Turso / libSQL)
# ─────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# ─────────────────────────────────────────────
# EMAIL — business owner's Gmail SMTP
# Use an App Password, NOT your Gmail password.
# Generate one at: myaccount.google.com/apppasswords
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=owner@gmail.com
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
FROM_NAME=Acme HVAC
FROM_EMAIL=owner@gmail.com

# Owner is CC'd on every outbound client email
CC_EMAIL=owner@gmail.com

# Daily digest goes here (defaults to FROM_EMAIL if not set)
DIGEST_EMAIL_TO=owner@gmail.com

# ─────────────────────────────────────────────
# SMS — Twilio (optional)
# Leave blank to run in stub/log-only mode.
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─────────────────────────────────────────────
# APP
# Used to build links inside emails (portal, quotes, invoices)
# ─────────────────────────────────────────────
APP_URL=https://gritly.vercel.app
